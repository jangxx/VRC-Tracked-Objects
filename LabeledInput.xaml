<UserControl x:Class="VRC_OSC_ExternallyTrackedObject.LabeledInput"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VRC_OSC_ExternallyTrackedObject"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="350">
    <Grid Height="30" x:Name="OuterShell">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding LabelWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Label
            Height="28"
            Content="{Binding LabelText, RelativeSource={RelativeSource AncestorType=UserControl}}"
            HorizontalAlignment="Left"
        />
        <TextBox 
            Grid.Column="1"
            Height="20"
            Text="{Binding InputText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Margin="0,0,5,0"
        />
    </Grid>
</UserControl>
